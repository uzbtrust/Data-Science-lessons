{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"1lRhVdmmlwIE6xN_DAaSZCkN7jAPUIP-I","timestamp":1745667481043},{"file_id":"1S8QXdOaSMgLUA6tY6kV7lE3Gh1LJWwW0","timestamp":1745667094720},{"file_id":"1rw1M78Z0iPJUtLYb47Y8Jjv8WUkSKpvJ","timestamp":1745664653677},{"file_id":"1Bgehz-2FfKN9qKYNFT4RprCvkUpavqFo","timestamp":1745648293687},{"file_id":"1fkmV6uXyAj-mCtvKHivOY5BAl_wQEqEq","timestamp":1745647858141},{"file_id":"1tDczzAQBs-gHmS_qt555-7Eus79Dy39r","timestamp":1745647231625},{"file_id":"182q4kTiHN0BaloJNJJt6CtydIPy65VfW","timestamp":1745593323360},{"file_id":"1Y-5XWTP1BU7vQMkRp8hQfLu_w-mR19gq","timestamp":1745592659761},{"file_id":"1pymO2BwsuytcztUdYGV3fBSn1SgdyTF0","timestamp":1745517040442},{"file_id":"15r9aEJt3pHa_HQeRJ4qKaxtjCSi1ZJGv","timestamp":1745515469919},{"file_id":"1Vvd0RfzYzUziC7uh6wxtIVw4q2XAIhxQ","timestamp":1745514718695},{"file_id":"1-h5yjfwSSNWUXyn4kqMUgE8o6tSzlxnR","timestamp":1745514246455},{"file_id":"17tTU-8DZSMXzZ4VwhCSR40EjNJVMOKC0","timestamp":1745513294799},{"file_id":"1hLJ8oFV50nQJJ0qMAq0g8Op3piHA4xrk","timestamp":1745512384724},{"file_id":"1nTEItCs2aRXkodQ9d9YuHY86HEVuWg6p","timestamp":1745511124107}],"authorship_tag":"ABX9TyMPPD7JWDiv05tjykjGzHcz"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["housing - original df\n","\n","housing_labels - y df\n","\n","housing_num - x df\n","\n","housing_tr - nan qiymatsiz df"],"metadata":{"id":"uJrhUy160afO"}},{"cell_type":"code","source":["import pandas as pd\n","import numpy as np\n","import sklearn\n","\n","df = pd.read_csv('https://raw.githubusercontent.com/ageron/handson-ml2/refs/heads/master/datasets/housing/housing.csv')\n","\n","from sklearn.model_selection import train_test_split\n","train_set, test_set = train_test_split(df, test_size=0.2, random_state=42)\n","\n","housing = train_set.drop(\"median_house_value\", axis=1)\n","housing_labels = train_set[\"median_house_value\"].copy()\n","\n","housing_num = housing.drop(\"ocean_proximity\", axis=1)"],"metadata":{"id":"BZgGQ_eXqASV","executionInfo":{"status":"ok","timestamp":1745667733692,"user_tz":-300,"elapsed":72,"user":{"displayName":"uzbtrust","userId":"14726810448574511543"}}},"execution_count":6,"outputs":[]},{"cell_type":"code","source":["from sklearn.base import BaseEstimator, TransformerMixin\n","\n","rooms_ix, bedrooms_ix, population_ix, households_ix = 3, 4, 5, 6\n","\n","class CombinedAttributesAdder(BaseEstimator, TransformerMixin):\n","    def __init__(self, add_bedrooms_per_room = True):\n","        self.add_bedrooms_per_room = add_bedrooms_per_room\n","    def fit(self, X, y=None):\n","        return self\n","    def transform(self, X):\n","        rooms_per_household = X[:, rooms_ix] / X[:, households_ix]\n","        population_per_household = X[:, population_ix] / X[:, households_ix]\n","        if self.add_bedrooms_per_room:\n","            bedrooms_per_room = X[:, bedrooms_ix] / X[:, rooms_ix]\n","            return np.c_[X, rooms_per_household, population_per_household, bedrooms_per_room]\n","        else:\n","            return np.c_[X, rooms_per_household, population_per_household]"],"metadata":{"id":"ji0Qnla14x1H","executionInfo":{"status":"ok","timestamp":1745667827246,"user_tz":-300,"elapsed":52,"user":{"displayName":"uzbtrust","userId":"14726810448574511543"}}},"execution_count":8,"outputs":[]},{"cell_type":"code","source":["from sklearn.pipeline import Pipeline\n","from sklearn.impute import SimpleImputer\n","from sklearn.preprocessing import OneHotEncoder, StandardScaler"],"metadata":{"id":"cf2f44zm6SRy","executionInfo":{"status":"ok","timestamp":1745668012202,"user_tz":-300,"elapsed":33,"user":{"displayName":"uzbtrust","userId":"14726810448574511543"}}},"execution_count":9,"outputs":[]},{"cell_type":"code","source":["num_pipline = Pipeline([\n","    ('imputer', SimpleImputer(strategy='median')),\n","    ('attribs_adder', CombinedAttributesAdder()),\n","    ('std_scaler', StandardScaler())\n","])\n","num_pipline.fit_transform(housing_num)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"_OE_sW0Q6_XK","executionInfo":{"status":"ok","timestamp":1745668270424,"user_tz":-300,"elapsed":77,"user":{"displayName":"uzbtrust","userId":"14726810448574511543"}},"outputId":"22c34727-8653-48cf-ec87-5b68a33671c0"},"execution_count":10,"outputs":[{"output_type":"execute_result","data":{"text/plain":["array([[ 1.27258656, -1.3728112 ,  0.34849025, ..., -0.17491646,\n","         0.05137609, -0.2117846 ],\n","       [ 0.70916212, -0.87669601,  1.61811813, ..., -0.40283542,\n","        -0.11736222,  0.34218528],\n","       [-0.44760309, -0.46014647, -1.95271028, ...,  0.08821601,\n","        -0.03227969, -0.66165785],\n","       ...,\n","       [ 0.59946887, -0.75500738,  0.58654547, ..., -0.60675918,\n","         0.02030568,  0.99951387],\n","       [-1.18553953,  0.90651045, -1.07984112, ...,  0.40217517,\n","         0.00707608, -0.79086209],\n","       [-1.41489815,  0.99543676,  1.85617335, ..., -0.85144571,\n","        -0.08535429,  1.69520292]])"]},"metadata":{},"execution_count":10}]},{"cell_type":"code","source":[],"metadata":{"id":"Od-fY7Gc7-X7"},"execution_count":null,"outputs":[]}]}